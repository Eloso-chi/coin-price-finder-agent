PCGS_API_KEY=
PCGS_BASE_URL=https://api.pcgs.com/publicapi

EBAY_APP_ID=
EBAY_CLIENT_SECRET=
EBAY_FINDING_ENDPOINT=https://svcs.ebay.com/services/search/FindingService/v1
EBAY_GLOBAL_ID=EBAY-US
EBAY_ENTRIES_PER_PAGE=50
EBAY_TIMEOUT_MS=10000
EBAY_CACHE_TTL_MS=3600000
EBAY_US_MIN_COMPS=8
EBAY_THROTTLE_MS=1100

GOLDAPI_KEY=
METALS_API_KEY=
METALS_CACHE_TTL_MS=2700000
METALS_POLL_MS=1800000

# Crash/ops alerting (optional)
SENDGRID_API_KEY=
ALERT_EMAIL_TO=
ALERT_FROM_EMAIL=alerts@coinpricefinder.app

# Azure Blob Storage for Terapeak CSVs (#99, #106)
TERAPEAK_BLOB_ACCOUNT=
TERAPEAK_BLOB_CONTAINER=terapeak-csvs
TERAPEAK_DATA_DIR=data/terapeak
# How often to re-import from blob (ms, default 30 min)
# BLOB_REIMPORT_MS=1800000

# Greysheet history refresh interval in days (default 3)
# GS_REFRESH_INTERVAL_DAYS=3

# PCGS prefetch scheduler (optional)
# PCGS_PREFETCH_ENABLED=true
# PREFETCH_HOUR_PT=23
# PREFETCH_THROTTLE_MS=1000
# PREFETCH_RESERVE=10

# Auction history refresh tuning (optional)
# APR_DATE_WINDOW_YEARS=3
# APR_FRESHNESS_DAYS=30

PORT=3000
