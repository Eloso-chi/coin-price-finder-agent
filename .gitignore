.env
.env.production
node_modules/
.DS_Store
cache/
!cache/greysheet_history.json

# Local scratch (assistant-generated helper scripts, ad-hoc queries, etc.)
.local/

# Python virtual environments (any variant created locally)
.venv*/

# Azure
iisnode/
*.publishsettings

# Database
*.db

# Test metrics data (local, append-only)
.test-metrics/*.jsonl
scripts/__pycache__/
scripts/cache.cookies.json
src/.vscode/
tests/__pycache__/
test-parse.js
test_output.log
scripts/run-multi-phase.sh

# Stryker mutation testing (BACKLOG #239)
reports/mutation/
.stryker-tmp/
stryker.log

# #246 Cosmos dumps -- too large for git, kept locally + Azure backup only
data/archive/cosmos-terapeak-sold-*.json

# #260 Backups created by scripts/sync-terapeak-meta.js when pulling Azure meta
data/archive/terapeak-meta.before-azure-sync-*.json

# Per-machine identity file (#264W). Value is "W" or "H".
# Setup: echo W > .machine-id   (Codespace / work) or
#        echo H > .machine-id   (home workstation)
# See docs/BACKLOG.rules.md "Per-machine ID convention".
/.machine-id

# Assistant / session scratch helpers (ad-hoc bash + diagnostic scripts at repo root).
# Anything matching `_*.sh` or `_*.json` at the top level is local-only.
/_*.sh
/_*.json
/_*.txt
/_*.md

# Local meta backups produced by ad-hoc dormancy hotfixes (see #269H).
data/terapeak-meta.*.bak.json
