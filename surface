#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$HOME/.env.surface"
LOADER_FILE="$HOME/load-cpf-env.sh"

if [[ ! -f "$LOADER_FILE" ]]; then
  echo "Missing $LOADER_FILE. Run: bash scripts/bootstrap-surface-wsl.sh" >&2
  exit 1
fi

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Missing $ENV_FILE. Run bootstrap and key setup first." >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$LOADER_FILE"

cd "$ROOT_DIR"
exec bash scripts/run-surface-freshness-loop.sh --env-file "$ENV_FILE" "$@"
